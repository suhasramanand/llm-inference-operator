FROM --platform=$BUILDPLATFORM golang:1.26 AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/mock-worker ./cmd/mock-worker

FROM gcr.io/distroless/static:nonroot
COPY --from=build /out/mock-worker /mock-worker
USER 65532:65532
ENTRYPOINT ["/mock-worker"]

